.card-widget
  .item-headline
    i.fa-solid.fa-quote-left
    span 今日一句
  .poem-wrap
    .poem-text#hitokoto 加载中...
    .poem-author#hitokoto_from

script.
  fetch('https://v1.hitokoto.cn/')
    .then(response => response.json())
    .then(data => {
      document.getElementById('hitokoto').innerHTML = data.hitokoto;
      document.getElementById('hitokoto_from').innerHTML = `—— ${data.from}`;
    })
    .catch(() => {
      document.getElementById('hitokoto').innerHTML = '一个人走路，是和地球的单独约会。';
    });